# Runtime
NODE_ENV=production
PORT=5000
DB_PROVIDER=sqlite
# Runtime default is sqlite.
# For official deployment, use managed Postgres once full runtime migration is complete.

# Persistence
# Use an absolute path in production for predictable storage.
DB_FILE=./data.db

# Postgres
# Required when DB_PROVIDER=postgres.
DATABASE_URL=

# Security / bootstrap
# In production, keep this false after first admin is created.
ALLOW_DEFAULT_ADMIN=false

# Hidden emergency superadmin (optional)
# If enabled, this account can log in but is hidden from Admin Panel user lists.
HIDDEN_SUPERADMIN_ENABLED=false
HIDDEN_SUPERADMIN_USERNAME=system_superadmin
HIDDEN_SUPERADMIN_EMAIL=system.superadmin@localhost
HIDDEN_SUPERADMIN_PASSWORD=ChangeMeNow123!

# Logging
# Set true only for short-term debugging (can include sensitive payload data).
LOG_RESPONSE_BODIES=false
