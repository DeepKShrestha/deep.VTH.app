# Runtime
NODE_ENV=production
PORT=5000
DB_PROVIDER=sqlite
# Runtime currently supports sqlite only.
# Postgres is enabled for migration/connectivity prep commands.

# Persistence
# Use an absolute path in production for predictable storage.
DB_FILE=./data.db

# Postgres (for Phase 2 dual-mode prep)
# Keep empty when DB_PROVIDER=sqlite.
DATABASE_URL=

# Security / bootstrap
# In production, keep this false after first admin is created.
ALLOW_DEFAULT_ADMIN=false

# Logging
# Set true only for short-term debugging (can include sensitive payload data).
LOG_RESPONSE_BODIES=false
