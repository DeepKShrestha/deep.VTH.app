# =============================================================================
# Copy to ".env" and adjust. The server loads dotenv in server/index.ts.
# Dev: "npm run dev" also sets SQLite + PORT=5001 via package.json (overrides).
# =============================================================================

# --- Runtime ---
NODE_ENV=production
PORT=5000
LOG_RESPONSE_BODIES=false

# --- Database ---
# sqlite | postgres
DB_PROVIDER=sqlite
# SQLite DB file. Use an absolute path in production.
DB_FILE=./data.db
# Required when DB_PROVIDER=postgres.
DATABASE_URL=

# --- Storage paths (production: prefer absolute paths) ---
# Case attachment files (default if unset: ./uploads/case-attachments)
# CASE_ATTACHMENTS_DIR=
# Superadmin full-site backup zip output (default if unset: ./backups/site)
# BACKUP_LOCAL_DIR=

# --- Security / bootstrap ---
# Required when running the production bundle (`npm start`): HMAC secret for signed
# attachment and profile-photo URLs (32+ characters).
ATTACHMENT_SIGNING_SECRET=
# Optional: signed URL TTL in ms, min 60000, max 86400000. Default 1800000 (30 min).
# ATTACHMENT_SIGNING_TTL_MS=

# In production, keep false after the first admin exists.
ALLOW_DEFAULT_ADMIN=false

# Hidden emergency superadmin (optional).
# If enabled, this account can log in but is hidden from Admin Panel user lists.
HIDDEN_SUPERADMIN_ENABLED=false
HIDDEN_SUPERADMIN_USERNAME=system_superadmin
HIDDEN_SUPERADMIN_EMAIL=system.superadmin@localhost
HIDDEN_SUPERADMIN_PASSWORD=ChangeMeNow123!

# --- Postgres site backup / restore (optional) ---
# Directory containing pg_dump and psql if not on PATH.
# PG_BIN=

# --- Optional S3 upload for site backups (superadmin backup UI) ---
# All of bucket + AWS keys must be set for upload to be considered configured.
# BACKUP_S3_BUCKET=
# BACKUP_S3_PREFIX=site-backups
# BACKUP_S3_REGION=us-east-1
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- SQLite CLI backup / restore scripts (optional) ---
# npm run backup:db — output directory (default: backups)
# DB_BACKUP_DIR=
# npm run restore:db — path to backup file to restore from
# DB_RESTORE_FROM=

# --- Temp case attachment cleanup (optional; sensible defaults if unset) ---
# Max age in hours for unlinked uploads (default: 72)
# TEMP_ATTACHMENTS_MAX_AGE_HOURS=
# Scheduler interval in ms, minimum 60000 (default: 21600000 = 6h)
# TEMP_ATTACHMENTS_CLEANUP_INTERVAL_MS=
